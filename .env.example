APP_ENV=development
# Generate a unique random value (32+ characters); never deploy the example value.
APP_SECRET_KEY=replace-with-a-unique-random-secret-of-at-least-32-characters
DATABASE_URL=postgresql+psycopg://vinted:vinted@postgres:5432/vinted_monitor
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5176
LOCAL_AUTH_PREAUTH_TTL_MINUTES=10
LOCAL_AUTH_SESSION_TTL_HOURS=168

POSTGRES_DB=vinted_monitor
POSTGRES_USER=vinted
POSTGRES_PASSWORD=vinted

VINTED_BASE_URL=https://www.vinted.es
VINTED_REQUEST_TIMEOUT_MS=15000
VINTED_REQUEST_RETRIES=1
VINTED_FAST_CATALOG_PER_PAGE=5
VINTED_DETAIL_MAX_CANDIDATES_PER_RUN=5
VINTED_DETAIL_CONCURRENCY=1
VINTED_DETAIL_FETCH_MODE=serial
VINTED_DETAIL_EARLY_FILTER_MODE=enforced
VINTED_DETAIL_HEAD_MAX_BYTES=131072
VINTED_DETAIL_REQUIRED_FIELDS=title,description,brand,size,status,price_amount,currency,photos
VINTED_DETAIL_MAX_ATTEMPTS=3
VINTED_DETAIL_RETRY_BACKOFFS_SECONDS=[30,120]

SEEN_CACHE_TTL_SECONDS=86400
SEEN_PROCESSING_TTL_SECONDS=120
SEEN_CACHE_MAX_PER_MONITOR=10000

# Worker: Producer-Consumer pattern
WORKER_CONSUMER_COUNT=2
WORKER_TASK_QUEUE_KEY=vinted:task_queue
WORKER_RESERVE_TIMEOUT_SECONDS=5
WORKER_MAX_RETRY_ATTEMPTS=3

# Anti-bot evasion (curl_cffi)
CURL_IMPERSONATE_BROWSER=chrome146
VINTED_DIRECT_CATALOG_ENABLED=false
VINTED_TARGET_COUNTRY_CODE=ES
VINTED_TARGET_LOCALE=es-ES
VINTED_TARGET_ACCEPT_LANGUAGE=en-GB,en;q=0.9
VINTED_TARGET_SCREEN=1920x1080
HUMAN_DELAY_MIN_SECONDS=1.2
HUMAN_DELAY_MAX_SECONDS=3.8
DATADOME_CHALLENGE_PENALTY_MULTIPLIER=2
# Provider-specific residential sticky-session username format.
# Examples: {username}-session-{session_id}, {username}-sessid-{session_id}
PROXY_STICKY_USERNAME_TEMPLATE={username}-session-{session_id}
EGRESS_DIAGNOSTIC_REUSE_TTL_SECONDS=300

SCHEDULER_ENABLED=false
SCHEDULER_MAX_CONCURRENT_RUNS=2
SCHEDULER_PER_SOURCE_CONCURRENCY=1
SCHEDULER_POLL_INTERVAL_SECONDS=5
SCHEDULER_WORKER_HEARTBEAT_INTERVAL_SECONDS=5
SCHEDULER_WORKER_HEARTBEAT_TIMEOUT_SECONDS=30
SCHEDULER_WATCHDOG_POLL_INTERVAL_SECONDS=5
SCHEDULER_WATCHDOG_STARTUP_GRACE_SECONDS=30
SCHEDULER_TIMEZONE=Europe/Madrid
LOG_LEVEL=INFO

# Future authenticated actions. Never commit real values.
VINTED_AUTH_ENABLED=false
VINTED_AUTH_COOKIE=
VINTED_AUTH_CSRF_TOKEN=
ACTION_REQUESTS_ENABLED=false

FRONTEND_API_BASE_URL=http://localhost:8000
